#!/usr/bin/env zsh
#
# gcsw — interactive gcloud configuration switcher
# https://github.com/arcmanagement/gcsw
#
# Pick a gcloud configuration from a list (fzf or a numbered menu), activate it,
# and align the ADC quota project to the new project — no browser needed.
#
emulate -L zsh

readonly GCSW_VERSION="0.3.2"
readonly GCSW_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gcsw"
readonly GCSW_KIRO_SPECS_KEY="autocomplete.devCompletionsFolder"

gcsw_help() {
  cat <<'EOF'
gcsw — interactive gcloud configuration switcher

Usage:
  gcsw                Pick a configuration interactively
  gcsw <pattern>      Switch to the first configuration matching <pattern>
  gcsw -a, --adc      Re-authenticate ADC in the browser (use when the account changes)
  gcsw update         Refresh the completion spec from the current configuration list
  gcsw -h, --help     Show this help
  gcsw -v, --version  Print version

Without -a, gcsw activates the chosen configuration and aligns the Application
Default Credentials (ADC) quota project to it without opening a browser. fzf is
used for the picker when installed; otherwise a numbered menu is shown.
EOF
}

# Resolve the completion-specs folder, or fail if unknown.
# Order: Kiro CLI's configured folder (source of truth) -> gcsw's saved path.
gcsw_specs_dir() {
  # If kiro-cli is installed and has a Specs folder set, drop the spec there.
  if command -v kiro-cli >/dev/null 2>&1; then
    local kdir; kdir=$(kiro-cli settings "$GCSW_KIRO_SPECS_KEY" 2>/dev/null)
    kdir=${kdir//\"/}
    [[ -n "$kdir" && "$kdir" != error:* ]] && { print -r -- "${kdir/#\~/$HOME}"; return 0 }
  fi
  if [[ -f "$GCSW_CONFIG_DIR/specs_dir" ]]; then
    local saved; saved=$(<"$GCSW_CONFIG_DIR/specs_dir")
    [[ -n "$saved" ]] && { print -r -- "$saved"; return 0 }
  fi
  return 1
}

# Write the Fig/Kiro completion spec, with the current configuration list baked
# in as static suggestions (plus a dynamic generator for tools that run it).
gcsw_update() {
  local specs_dir
  if ! specs_dir=$(gcsw_specs_dir); then
    print "gcsw: completion specs folder is not set yet."
    print "  In Kiro CLI: settings -> Developer -> enable Dev mode, then set the Specs folder."
    printf 'Enter the specs folder path: '
    local input; read -r input
    [[ -z "$input" ]] && { print -u2 "gcsw: no path given, aborting."; return 1 }
    specs_dir="${input/#\~/$HOME}"
    mkdir -p "$GCSW_CONFIG_DIR"
    print -r -- "$specs_dir" > "$GCSW_CONFIG_DIR/specs_dir"
    command -v kiro-cli >/dev/null 2>&1 && \
      kiro-cli settings "$GCSW_KIRO_SPECS_KEY" "$specs_dir" >/dev/null 2>&1
    print "gcsw: saved specs folder -> $specs_dir"
  fi

  mkdir -p "$specs_dir" || { print -u2 "gcsw: cannot create $specs_dir"; return 1 }

  local -a configs
  configs=(${(f)"$(gcloud config configurations list --format='value(name)' 2>/dev/null)"})
  if (( ${#configs} == 0 )); then
    print -u2 "gcsw: no gcloud configurations found"; return 1
  fi

  # Kiro loads plain .js specs (NOT .ts). Drop any stale .ts we wrote before.
  rm -f "$specs_dir/gcsw.ts"
  local spec="$specs_dir/gcsw.js" c
  {
    cat <<HEADER
// Auto-generated by 'gcsw update'. Do not edit by hand.
// Re-run 'gcsw update' to refresh the configuration list.
const configurations = [
HEADER
    for c in $configs; do print -- "  \"$c\","; done
    cat <<'SPEC'
];

const completionSpec = {
  name: "gcsw",
  description: "Interactive gcloud configuration switcher",
  subcommands: [
    {
      name: "update",
      description: "Refresh the completion spec from the current configuration list",
    },
  ],
  args: {
    name: "configuration",
    description: "gcloud configuration to switch to",
    isOptional: true,
    suggestions: configurations.map((name) => ({
      name,
      description: "gcloud configuration",
      icon: "⚙️",
    })),
    generators: {
      script: ["gcloud", "config", "configurations", "list", "--format=value(name)"],
      postProcess: (out) =>
        out
          .split("\n")
          .filter((l) => l.trim().length > 0)
          .map((name) => ({ name, description: "gcloud configuration", icon: "⚙️" })),
    },
  },
  options: [
    { name: ["-a", "--adc"], description: "Re-authenticate ADC in the browser" },
    { name: ["-h", "--help"], description: "Show this help" },
    { name: ["-v", "--version"], description: "Print version" },
  ],
};

export default completionSpec;
SPEC
  } > "$spec"

  print "gcsw: wrote ${#configs} configurations -> $spec"
}

gcsw_main() {
  if [[ "$1" == "update" ]]; then
    shift; gcsw_update "$@"; return $?
  fi

  local adc_full=0 pattern=""
  for arg in "$@"; do
    case "$arg" in
      -h|--help)    gcsw_help; return 0 ;;
      -v|--version) print "gcsw ${GCSW_VERSION}"; return 0 ;;
      -a|--adc)     adc_full=1 ;;
      --)           ;;
      -*)           print -u2 "gcsw: unknown option '$arg' (try --help)"; return 2 ;;
      *)            pattern="$arg" ;;
    esac
  done

  if ! command -v gcloud >/dev/null 2>&1; then
    print -u2 "gcsw: gcloud not found. Install the Google Cloud CLI first."
    return 1
  fi

  local cfg
  if [[ -n "$pattern" ]]; then
    cfg=$(gcloud config configurations list --format='value(name)' | grep -i -- "$pattern" | head -1)
    if [[ -z "$cfg" ]]; then
      print -u2 "gcsw: no configuration matching '$pattern'"
      return 1
    fi
  elif command -v fzf >/dev/null 2>&1; then
    cfg=$(gcloud config configurations list | fzf --header-lines=1 --height=40% --reverse \
            --prompt='gcloud config> ' | awk '{print $1}')
  else
    local -a names; names=("${(@f)$(gcloud config configurations list --format='value(name)')}")
    local i=1 n; for n in $names; do printf '%2d) %s\n' $i "$n"; ((i++)); done
    printf 'select number (or name): '
    local sel; read -r sel
    if [[ "$sel" == <-> ]]; then cfg="${names[$sel]}"; else cfg="$sel"; fi
  fi
  [[ -z "$cfg" ]] && return 1

  gcloud config configurations activate "$cfg" >/dev/null || return 1

  local proj account
  proj=$(gcloud config get-value project 2>/dev/null)
  account=$(gcloud config get-value account 2>/dev/null)

  if (( adc_full )); then
    gcloud auth application-default login
  elif [[ -n "$proj" ]]; then
    if gcloud auth application-default set-quota-project "$proj" >/dev/null 2>&1; then
      print "  ADC quota project -> $proj"
    else
      print "  ADC quota project unchanged (no permission on $proj)"
    fi
  fi

  print "OK  $cfg  [${account:-no account} / ${proj:-no project}]"
}

gcsw_main "$@"
