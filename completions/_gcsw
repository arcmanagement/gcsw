#compdef gcsw
# zsh completion for gcsw — gcloud configuration names are completed dynamically.

local curcontext="$curcontext" state line
local -a configs

_arguments -C \
  '(-a --adc)'{-a,--adc}'[Re-authenticate ADC in the browser]' \
  '(-h --help)'{-h,--help}'[Show this help]' \
  '(-v --version)'{-v,--version}'[Print version]' \
  '1: :->configuration'

case "$state" in
  configuration)
    configs=(${(f)"$(gcloud config configurations list --format='value(name)' 2>/dev/null)"})
    _describe -t configurations 'gcloud configuration' configs
    ;;
esac
